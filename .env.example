# ─── Witness Agents — Environment Variables ──────────────────────────
# Copy to `.env` and fill in your values. Do NOT commit `.env`.

# Selemene Engine
SELEMENE_API_URL=https://selemene.tryambakam.space
SELEMENE_API_KEY=

# LLM Provider (one or both)
# - If only one is set, that provider is used.
# - If both are set, OpenRouter wins by default. Set LLM_PROVIDER=nvidia to override.
OPENROUTER_API_KEY=
NVIDIA_API_KEY=

# Optional: force a provider regardless of which keys are set.
# Values: openrouter | nvidia
# LLM_PROVIDER=nvidia

# Server
PORT=3333
WITNESS_TIER=witness-initiate
# WITNESS_KNOWLEDGE_PATH=/abs/path/to/knowledge
